APP_IMAGE=registry.example.com/workflow-backend:replace-with-git-commit
COMPOSE_PROJECT_NAME=workflow-server
APP_VERSION=replace-with-git-commit

DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=api.example.com
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8000

MYSQL_DATABASE=workflow
MYSQL_USER=workflow
MYSQL_PASSWORD=replace-me
MYSQL_ROOT_PASSWORD=replace-me-too

RABBITMQ_DEFAULT_USER=workflow
RABBITMQ_DEFAULT_PASS=replace-me
CELERY_QUEUE=workflow-server
WORKFLOW_RETENTION_HOURS=24
JOB_RETENTION_HOURS=720
JOB_LOG_RETENTION_HOURS=168
JOB_MAX_LOGS=5000
JOB_MAX_HTTP_BODY_BYTES=65536
PRODUCT_APPLICATION_TIMEOUT_SECONDS=300
MOCK_FIXED_SYSTEM_TOKEN=replace-with-fixed-external-system-token
