APP_VERSION=replace-with-git-commit
EXTERNAL_SYSTEM_MODE=real

DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_ALLOWED_HOSTS=api.example.com
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=9000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=alkaid_prod
MYSQL_USER=workflow
MYSQL_PASSWORD=replace-me
MYSQL_SSL_DISABLED=true

CELERY_BROKER_URL=amqp://workflow:replace-me@127.0.0.1:5672//
CELERY_QUEUE=alkaid-prod
CELERY_TASK_ALWAYS_EAGER=false
JOB_RETENTION_HOURS=720
JOB_LOG_RETENTION_HOURS=168
JOB_MAX_LOGS=5000
JOB_MAX_HTTP_BODY_BYTES=65536
JOB_RECONCILE_BATCH_SIZE=500
JOB_SSE_POLL_SECONDS=1
JOB_SSE_HEARTBEAT_SECONDS=15
PRODUCT_APPLICATION_TIMEOUT_SECONDS=300
APPLICATION_LINK_TIMEOUT_SECONDS=120
BUSINESS_ACCESS_TIMEOUT_SECONDS=120
VERIFICATION_APPROVAL_TIMEOUT_SECONDS=120
APPLICATION_DATA_TIMEOUT_SECONDS=300
CARD_STATUS_TIMEOUT_SECONDS=120
LOAN_STATUS_TIMEOUT_SECONDS=120
MOCK_FIXED_SYSTEM_TOKEN=replace-with-fixed-external-system-token
MOCK_PRODUCT_BASE_URL=https://product-system.internal
APPLICATION_LINK_BASE_URL=https://application-link-system.internal
APPLICATION_LINK_API_TOKEN=replace-with-application-link-token
BUSINESS_ACCESS_BASE_URL=https://business-access-system.internal
BUSINESS_ACCESS_API_TOKEN=replace-with-business-access-token
VERIFICATION_APPROVAL_BASE_URL=https://verification-system.internal
VERIFICATION_APPROVAL_API_TOKEN=replace-with-verification-token
HTTP_TIMEOUT_SECONDS=10
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_POOL_TIMEOUT_SECONDS=5
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=0.2
HTTP_RETRY_MAX_BACKOFF_SECONDS=5
