{
  "product": {
    "code": "product-b",
    "name": "产品B",
    "product_type": "red_shield_product",
    "handler": "red_shield_application_v1",
    "switch_field": "red_shield_enabled",
    "default_application_method": "normal",
    "ownership_categories": [
      {"code": "farmer", "name": "农户"},
      {"code": "legal_person", "name": "法人"},
      {"code": "shareholder", "name": "股东"}
    ],
    "organizations": [
      {"code": "example-branch", "name": "示例机构"}
    ],
    "common_field_sets": ["customer_base", "organization_base"],
    "application_methods": {
      "normal": {
        "name": "普通申请",
        "operation": "mock_product.product_b.apply",
        "fields": ["red_shield_enabled"],
        "required_fields": ["red_shield_enabled"]
      },
      "dynamic": {
        "name": "动态申请",
        "operation": "mock_product.product_b.dynamic_apply",
        "fields": ["red_shield_enabled", "dynamic_term", "dynamic_amount"],
        "required_fields": ["red_shield_enabled", "dynamic_term", "dynamic_amount"]
      }
    }
  }
}
