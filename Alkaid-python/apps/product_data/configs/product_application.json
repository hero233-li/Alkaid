{
  "id": "product-application-example",
  "version": 4,
  "environments": [
    {"label": "环境1", "value": "env-1"},
    {"label": "环境2", "value": "env-2"},
    {"label": "环境3", "value": "env-3"}
  ],
  "products": [
    {
      "label": "产品A",
      "value": "product-a",
      "environments": ["env-1", "env-2", "env-3"],
      "fieldSets": ["selection", "customerBase", "enterprise", "whitelist", "redShield"],
      "locations": [
        {
          "label": "广东省广州市",
          "value": "广东省广州市",
          "branches": [
            {
              "label": "广东省机构",
              "value": "广东省机构",
              "outlets": [
                {"label": "广东省网点", "value": "广东省网点"}
              ]
            }
          ]
        }
      ],
      "requiredFields": ["personName", "certificateNo","cardNo",  "phone", "whitelistEnabled", "redShieldEnabled"]
    },
    {
      "label": "产品B",
      "value": "product-b",
      "environments": ["env-1", "env-2", "env-3"],
      "fieldSets": ["selection", "customerBase", "enterprise", "redShield"],
      "locations": [
        {
          "label": "示例地区",
          "value": "example-location",
          "branches": [
            {
              "label": "示例机构",
              "value": "example-branch",
              "outlets": [
                {"label": "示例网点", "value": "example-outlet"}
              ]
            }
          ]
        }
      ],
      "requiredFields": ["personName", "certificateNo", "phone", "redShieldEnabled"]
    },
    {
      "label": "产品C",
      "value": "product-c",
      "environments": ["env-1", "env-2", "env-3"],
      "fieldSets": ["selection", "customerBase", "enterprise", "credit"],
      "locations": [
        {
          "label": "示例地区",
          "value": "example-location",
          "branches": [
            {
              "label": "示例机构",
              "value": "example-branch",
              "outlets": [
                {"label": "示例网点", "value": "example-outlet"}
              ]
            }
          ]
        }
      ],
      "requiredFields": ["personName", "certificateNo", "phone", "creditEnabled"]
    }
  ],
  "fieldSets": {
    "selection": ["environment", "product", "location", "branch", "outlet"],
    "customerBase": ["personName", "certificateNo", "cardNo", "phone"],
    "enterprise": ["companyName", "creditCode", "legalPerson"],
    "whitelist": ["whitelistEnabled"],
    "redShield": ["redShieldEnabled"],
    "credit": ["creditEnabled"]
  },
  "fields": [
    {"name": "environment", "label": "环境", "control": "select", "required": true, "persistDraft": true},
    {"name": "product", "label": "产品", "control": "select", "required": true, "persistDraft": true},
    {"name": "location", "label": "地区", "control": "select", "required": true, "persistDraft": true},
    {"name": "branch", "label": "机构", "control": "select", "required": true, "persistDraft": true},
    {"name": "outlet", "label": "网点", "control": "select", "required": true, "persistDraft": true},
    {"name": "personName", "label": "客户姓名", "control": "input", "required": true},
    {"name": "certificateNo", "label": "证件号码", "control": "input", "required": true},
    {"name": "cardNo", "label": "卡号", "control": "input", "required": true},
    {"name": "phone", "label": "手机号码", "control": "input", "required": true},
    {"name": "companyName", "label": "企业名称", "control": "input"},
    {"name": "creditCode", "label": "统一社会信用代码", "control": "input"},
    {"name": "legalPerson", "label": "客户类型", "control": "switch", "defaultValue": true, "submit": false, "persistDraft": true},
    {"name": "whitelistEnabled", "label": "白名单", "control": "switch", "required": true, "defaultValue": true, "checkedLabel": "开启", "uncheckedLabel": "关闭"},
    {"name": "redShieldEnabled", "label": "红盾", "control": "switch", "required": true, "defaultValue": true, "checkedLabel": "开启", "uncheckedLabel": "关闭"},
    {"name": "creditEnabled", "label": "征信", "control": "switch", "required": true, "defaultValue": true, "checkedLabel": "开启", "uncheckedLabel": "关闭"}
  ],
  "cascadeResetMap": {
    "environment": ["product", "location", "branch", "outlet"],
    "product": ["location", "branch", "outlet"],
    "location": ["branch", "outlet"],
    "branch": ["outlet"]
  }
}
