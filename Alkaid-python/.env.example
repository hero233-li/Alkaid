DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
APP_VERSION=dev
EXTERNAL_SYSTEM_MODE=mock

DB_ENGINE=mysql
FRONTEND_DIST_DIR=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=alkaid_dev
MYSQL_USER=workflow
MYSQL_PASSWORD=replace-me
MYSQL_SSL_DISABLED=true

CELERY_BROKER_URL=amqp://workflow:workflow@127.0.0.1:5672//
CELERY_QUEUE=alkaid-local
CELERY_TASK_ALWAYS_EAGER=false
DEV_START_WORKER=true

JOB_RETENTION_HOURS=720
JOB_LOG_RETENTION_HOURS=168
JOB_MAX_LOGS=5000
JOB_MAX_HTTP_BODY_BYTES=65536
JOB_RECONCILE_BATCH_SIZE=500
JOB_SSE_POLL_SECONDS=1
JOB_SSE_HEARTBEAT_SECONDS=15
PRODUCT_APPLICATION_TIMEOUT_SECONDS=300
APPLICATION_LINK_TIMEOUT_SECONDS=120
BUSINESS_ACCESS_TIMEOUT_SECONDS=120
VERIFICATION_APPROVAL_TIMEOUT_SECONDS=120
MOCK_FIXED_SYSTEM_TOKEN=mock-fixed-token
MOCK_PRODUCT_BASE_URL=
HTTP_TIMEOUT_SECONDS=10
HTTP_CONNECT_TIMEOUT_SECONDS=5
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_POOL_TIMEOUT_SECONDS=5
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=0.2
HTTP_RETRY_MAX_BACKOFF_SECONDS=5
EXAMPLE_SYSTEM_BASE_URL=https://example.invalid
EXAMPLE_SYSTEM_TOKEN=
APPLICATION_LINK_BASE_URL=
APPLICATION_LINK_API_TOKEN=
BUSINESS_ACCESS_BASE_URL=
BUSINESS_ACCESS_API_TOKEN=
VERIFICATION_APPROVAL_BASE_URL=
VERIFICATION_APPROVAL_API_TOKEN=
VERIFICATION_APPROVAL_DEBUG_DELAY_SECONDS=0

WEB_PORT=8000
